# ---- Bankdata-leverandør ----
# "enablebanking" (anbefalt, gratis personlig bruk) eller "gocardless"
# (nye GoCardless-registreringer er stengt siden juli 2025).
PROVIDER=enablebanking

# ---- Enable Banking ----
# Registrer app på https://enablebanking.com/cp, last opp den offentlige nøkkelen,
# og lim inn Application ID her. Se ENABLEBANKING_SETUP.md.
ENABLEBANKING_APP_ID=
# Sti til privat RSA-nøkkel. La stå tom for standard (data/enablebanking_private.pem
# relativt til appen) – funker for både LXC og Docker. Sett den kun ved egen plassering.
ENABLEBANKING_KEY_PATH=

# ---- GoCardless Bank Account Data (kun eksisterende kontoer) ----
# Hentes fra https://bankaccountdata.gocardless.com/ (Developers -> User secrets)
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=

# ---- App ----
# Adressen appen nås på i nettleseren. MÅ være riktig, for banken sender
# deg tilbake hit etter innlogging. Bruk serverens IP eller domene.
# Eksempel: http://192.168.1.50:8080  eller  https://okonomi.hjemme.no
APP_BASE_URL=http://192.168.1.50:8080

# Porten appen lytter på (host-side)
PORT=8080

# Land for banklisten (ISO alfa-2). Norge = no
COUNTRY=no

# Antall dager transaksjonshistorikk som hentes (norske banker gir ofte 90)
ACCESS_DAYS=90

# ---- Enkel tilgangsbeskyttelse (anbefalt) ----
# Settes APP_PASSWORD, kreves innlogging (nettleseren spør) for hele appen.
APP_USER=familien
APP_PASSWORD=

# Hemmelig nøkkel for signering — sett en lang tilfeldig streng
SECRET_KEY=bytt-meg-til-noe-langt-og-tilfeldig

# Minimum timer mellom automatiske synk per konto (ratebegrensning: ~4/døgn)
SYNC_MIN_INTERVAL_HOURS=6

# Automatisk daglig synk i bakgrunnen. AUTO_SYNC=0 skrur den av.
AUTO_SYNC=1
# Klokketime (0–23, servertid) for den daglige synken.
AUTO_SYNC_HOUR=5

# ---- KI-analyse (valgfritt) ----
# Settes ANTHROPIC_API_KEY, får dashboardet en «KI-analyse»-knapp som flagger
# avvik, mulige datafeil og gir konkrete råd. Uten nøkkel brukes den vanlige
# regelbaserte oppsummeringen og INGEN data forlater serveren.
# PERSONVERN: kun aggregerte tall sendes (kategorisummer, inntekt/forbruk/
# budsjett/sparerate/lånerenter) – aldri enkelttransaksjoner, mottakere eller navn.
# Nøkkel opprettes på https://console.anthropic.com (du betaler per bruk selv).
ANTHROPIC_API_KEY=
# Modell (standard: claude-sonnet-5). Billigere: claude-haiku-4-5.
AI_MODEL=claude-sonnet-5
